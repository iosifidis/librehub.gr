---
interface Props {
  title: string;
  alternative_to: string[];
  categories: string[];
  logo: string;
  license: string;
  description: string;
  website: string;
  slug: string;
  featured?: boolean;
}

const { title, alternative_to, categories, logo, license, description, website, slug, featured } = Astro.props;
const altText = alternative_to.join(', ');
const searchText = [title, ...alternative_to, ...categories, description].join(' ').toLowerCase();
---

<article
  data-categories={JSON.stringify(categories)}
  data-search-text={searchText}
  data-featured={featured ? 'true' : 'false'}
  class={`group relative flex flex-col rounded-2xl border bg-white dark:bg-gray-900 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 overflow-hidden ${featured ? 'border-green-300 dark:border-green-700 ring-1 ring-green-200 dark:ring-green-800' : 'border-gray-200 dark:border-gray-800'}`}
>
  <div class="p-5 flex flex-col flex-1">
    <!-- Logo + Title -->
    <div class="flex items-start gap-4 mb-4">
      <div class="flex-shrink-0 h-14 w-14 rounded-xl overflow-hidden bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm">
        <img
          src={logo}
          alt={`${title} logo`}
          class="h-full w-full object-contain p-1"
          loading="lazy"
          onerror="this.onerror=null; this.src='/images/placeholder.svg';"
        />
      </div>
      <div class="flex-1 min-w-0">
        <h2 class="text-lg font-bold text-gray-900 dark:text-white leading-tight group-hover:text-green-600 dark:group-hover:text-green-400 transition-colors duration-200 break-words">
          {title}
        </h2>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <!-- License badge -->
          <span class="inline-block rounded-md bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 text-xs font-mono text-gray-500 dark:text-gray-400">
            {license}
          </span>
          <!-- Featured badge -->
          {featured && (
            <span class="inline-flex items-center gap-1 rounded-md px-1.5 py-0.5 text-xs font-semibold" style="background-color: var(--accent-bg); color: var(--accent-text);">
              <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" focusable="false">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              Δημοφιλές
            </span>
          )}
        </div>
      </div>
    </div>

    <!-- Alternative To badge -->
    <div class="mb-3">
      <div class="inline-flex items-center gap-1.5 rounded-lg px-2.5 py-1.5 max-w-full border" style="background-color: var(--accent-bg); border-color: var(--accent-border); color: var(--accent-text);">
        <svg class="h-3.5 w-3.5 flex-shrink-0" style="color: var(--accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 3M21 7.5H7.5"/>
        </svg>
        <span class="text-xs font-medium truncate" style="color: var(--accent-text);">
          Εναλλακτικό του: <strong>{altText}</strong>
        </span>
      </div>
    </div>

    <!-- Description -->
    <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed line-clamp-3 flex-1 mb-4">
      {description}
    </p>

    <!-- Categories -->
    <div class="flex flex-wrap gap-1.5 mb-4">
      {categories.map((cat) => (
        <button
          type="button"
          data-category-filter={cat}
          class="inline-block rounded-full bg-green-50 dark:bg-green-950/60 text-green-700 dark:text-green-300 border border-green-200 dark:border-green-800 px-2.5 py-0.5 text-xs font-medium hover:bg-green-100 dark:hover:bg-green-900 transition-colors duration-150 cursor-pointer"
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-2 mt-auto pt-3 border-t border-gray-100 dark:border-gray-800">
      <a
        href={website}
        target="_blank"
        rel="noopener noreferrer"
        id={`card-link-${slug}`}
        aria-label={`Επίσκεψη ιστοσελίδας ${title} (ανοίγει σε νέα καρτέλα)`}
        class="flex-1 flex items-center justify-center gap-2 rounded-xl bg-green-600 hover:bg-green-700 px-3 py-2 text-sm font-medium text-white transition-all duration-200 shadow-sm hover:shadow-md"
      >
        Επίσκεψη Ιστοσελίδας
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
        </svg>
      </a>
      <a
        href={`/software/${slug}`}
        class="flex items-center justify-center rounded-xl border border-gray-200 dark:border-gray-700 px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors duration-200"
        aria-label={`Λεπτομέρειες για ${title}`}
      >
        Λεπτομέρειες
      </a>
    </div>
  </div>
</article>

<script>
  // Category filter click from within cards
  document.querySelectorAll('[data-category-filter]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const cat = (btn as HTMLElement).dataset.categoryFilter;
      if (cat && (window as any).filterByCategory) {
        (window as any).filterByCategory(cat);
        document.getElementById('software-grid-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
</script>
