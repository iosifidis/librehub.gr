---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allSoftware = await getCollection('software');
  return allSoftware.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, alternative_to, categories, logo, license, description, website } = entry.data;
---

<BaseLayout title={title} description={description}>
  <Header />
  <main class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-8 flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
      <a href="/" class="hover:text-green-600 dark:hover:text-green-400 transition-colors">Αρχική</a>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/>
      </svg>
      <span class="text-gray-900 dark:text-white font-medium">{title}</span>
    </nav>

    <!-- Header card -->
    <div class="rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6 sm:p-8 shadow-sm mb-8">
      <div class="flex items-start gap-6 mb-6">
        <img
          src={logo}
          alt={`${title} logo`}
          class="h-20 w-20 rounded-2xl object-contain p-2 bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm flex-shrink-0"
          onerror="this.src='/images/placeholder.svg'"
        />
        <div class="flex-1 min-w-0">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">{title}</h1>
          <div class="mt-2 flex flex-wrap gap-2">
            <span class="rounded-md bg-gray-100 dark:bg-gray-800 px-2 py-0.5 text-xs font-mono text-gray-500 dark:text-gray-400">{license}</span>
            {categories.map(cat => (
              <a href={`/category/${cat.toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '')}`}
                class="rounded-full bg-green-50 dark:bg-green-950 text-green-700 dark:text-green-300 border border-green-200 dark:border-green-800 px-2.5 py-0.5 text-xs font-medium hover:bg-green-100 transition-colors">
                {cat}
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="mb-4 inline-flex items-center gap-2 rounded-lg px-3 py-2 border" style="background-color: var(--accent-bg); border-color: var(--accent-border);">
        <svg class="h-4 w-4 flex-shrink-0" style="color: var(--accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 3M21 7.5H7.5"/>
        </svg>
        <span class="text-sm font-medium" style="color: var(--accent-text);">
          Εναλλακτικό του: <strong>{alternative_to.join(', ')}</strong>
        </span>
      </div>

      <p class="text-gray-600 dark:text-gray-400 leading-relaxed">{description}</p>

      <a
        href={website}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex items-center gap-2 rounded-xl bg-green-600 hover:bg-green-700 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:shadow-md transition-all duration-200"
      >
        Επίσκεψη Ιστοσελίδας
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
        </svg>
      </a>
    </div>

    <!-- Markdown content -->
    <div class="prose prose-gray dark:prose-invert max-w-none rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6 sm:p-8 shadow-sm">
      <Content />
    </div>
  </main>
  <Footer />
</BaseLayout>
