---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import CategoryFilter from '../components/CategoryFilter.astro';
import SoftwareGrid from '../components/SoftwareGrid.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allSoftware = await getCollection('software');

// Extract unique categories
const allCategories = [...new Set(allSoftware.flatMap((s) => s.data.categories))].sort((a, b) =>
  a.localeCompare(b, 'el')
);
---

<BaseLayout
  title="Ανοιχτές λύσεις για κάθε ανάγκη"
  description="Ανακαλύψτε ανοιχτού κώδικα εναλλακτικά λύσεις για ιδιόκτητο λογισμικό. Δωρεάν, ελεύθερο και ανοιχτό λογισμικό για κάθε ανάγκη."
>
  <Header />

  <main id="main-content">
    <!-- Hero with search -->
    <Hero totalCount={allSoftware.length} />

    <!-- Software directory section -->
    <section id="software-grid-section" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
      <!-- Section header -->
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Κατάλογος Λογισμικού</h2>
        <p class="mt-1 text-gray-500 dark:text-gray-400 text-sm">
          Αναζητήστε και φιλτράρετε από {allSoftware.length} ανοιχτού κώδικα εργαλεία.
        </p>
      </div>

      <!-- Category filter -->
      <div id="categories" class="mb-6">
        <CategoryFilter categories={allCategories} />
      </div>

      <!-- Grid -->
      <SoftwareGrid entries={allSoftware} />
    </section>

    <!-- CTA Banner -->
    <section class="bg-gradient-to-r from-green-600 to-emerald-500 dark:from-green-800 dark:to-emerald-700">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12 text-center">
        <h2 class="text-2xl font-bold text-white sm:text-3xl">
          Γνωρίζετε κάποιο λογισμικό που λείπει;
        </h2>
        <p class="mt-4 text-green-100 text-base max-w-xl mx-auto">
          Βοηθήστε μας να επεκτείνουμε τον κατάλογο. Προτείνετε νέο ανοιχτού κώδικα λογισμικό
          και θα το εξετάσουμε για προσθήκη.
        </p>
        <a
          href="/suggest"
          class="mt-6 inline-flex items-center gap-2 rounded-xl bg-white text-green-700 hover:bg-green-50 px-6 py-3 text-sm font-semibold shadow-lg hover:shadow-xl transition-all duration-200"
          id="cta-suggest-link"
          aria-label="Προτείνετε Λογισμικό για προσθήκη στον κατάλογο"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
          </svg>
          Προτείνετε Λογισμικό
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
