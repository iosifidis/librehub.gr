---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { categoryToSlug } from '../../utils/slugify';

export async function getStaticPaths() {
  const allSoftware = await getCollection('software');
  const allCategories = [...new Set(allSoftware.flatMap((s) => s.data.categories))];

  return allCategories.map((category) => ({
    params: { slug: categoryToSlug(category) },
    props: {
      category,
      entries: allSoftware.filter((s) => s.data.categories.includes(category)),
    },
  }));
}

interface Props {
  category: string;
  entries: Awaited<ReturnType<typeof getCollection<'software'>>>;
}

const { category, entries } = Astro.props;
---

<BaseLayout
  title={`${category} — Ελεύθερο Λογισμικό`}
  description={`Ανοιχτού κώδικα λογισμικό στην κατηγορία ${category}.`}
>
  <Header />
  <main id="main-content" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <nav class="mb-8 flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
      <a href="/" class="hover:text-green-600 dark:hover:text-green-400 transition-colors">Αρχική</a>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/>
      </svg>
      <span class="text-gray-900 dark:text-white font-medium" aria-current="page">{category}</span>
    </nav>
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">{category}</h1>
      <p class="mt-2 text-gray-500 dark:text-gray-400">
        {entries.length} εργαλεία ανοιχτού κώδικα στην κατηγορία <strong>{category}</strong>.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      {entries.map((entry) => (
        <article class="flex flex-col rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 overflow-hidden p-5" aria-label={entry.data.title}>
          <div class="flex items-start gap-4 mb-4">
            <img src={entry.data.logo} alt={`${entry.data.title} logo`} class="h-14 w-14 rounded-xl object-contain p-1 bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700" loading="lazy" onerror="this.src='/images/placeholder.svg'" />
            <div class="flex-1 min-w-0">
              <h2 class="text-lg font-bold text-gray-900 dark:text-white leading-tight">{entry.data.title}</h2>
              <span class="text-xs font-mono text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 rounded px-1.5 py-0.5">{entry.data.license}</span>
            </div>
          </div>
          <div class="mb-3 inline-flex items-center gap-1.5 rounded-lg px-2.5 py-1.5 border" style="background-color: var(--accent-bg); border-color: var(--accent-border);">
            <span class="text-xs font-medium truncate" style="color: var(--accent-text);">Εναλλακτικό του: <strong>{entry.data.alternative_to.join(', ')}</strong></span>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-3 flex-1 mb-4">{entry.data.description}</p>
          <a href={entry.data.website} target="_blank" rel="noopener noreferrer"
             aria-label={`Επίσκεψη ιστοσελίδας ${entry.data.title} (ανοίγει σε νέα καρτέλα)`}
             class="flex items-center justify-center gap-2 rounded-xl bg-green-600 hover:bg-green-700 px-3 py-2 text-sm font-medium text-white transition-all duration-200">
            Επίσκεψη Ιστοσελίδας
          </a>
        </article>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>
