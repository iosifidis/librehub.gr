---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Η Πρότασή σας Ελήφθη" description="Ευχαριστούμε για την πρότασή σας.">
  <Header />
  <main class="mx-auto max-w-lg px-4 sm:px-6 py-24 text-center">
    <div class="flex justify-center mb-6">
      <div class="flex h-16 w-16 items-center justify-center rounded-full bg-green-100 dark:bg-green-900/50">
        <svg class="h-8 w-8 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
        </svg>
      </div>
    </div>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Ευχαριστούμε!</h1>
    <p class="mt-4 text-gray-600 dark:text-gray-400 leading-relaxed">
      Η πρότασή σας ελήφθη με επιτυχία. Θα την εξετάσουμε και αν πληροί τα κριτήριά μας, θα την προσθέσουμε στον κατάλογο.
    </p>
    <a href="/" class="mt-8 inline-flex items-center gap-2 rounded-xl bg-green-600 hover:bg-green-700 px-5 py-2.5 text-sm font-semibold text-white transition-all duration-200">
      Επιστροφή στην Αρχική
    </a>
  </main>
  <Footer />
</BaseLayout>
