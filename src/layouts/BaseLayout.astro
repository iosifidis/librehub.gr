---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Ανακαλύψτε ανοιχτού κώδικα εναλλακτικά λύσεις για ιδιόκτητο λογισμικό. Δωρεάν, ελεύθερο και ανοιχτό λογισμικό για κάθε ανάγκη.',
  image = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="el" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/ellak_logo.png" sizes="200x200" />
    <link rel="apple-touch-icon" href="/ellak_logo.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title} | Μάθε για το ΕΛ/ΛΑΚ</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Μάθε για το ΕΛ/ΛΑΚ`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Prevent dark mode flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body
    class="min-h-screen bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 font-[Inter,system-ui,sans-serif] transition-colors duration-300"
  >
    <slot />
  </body>
</html>
